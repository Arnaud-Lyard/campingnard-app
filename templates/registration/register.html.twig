{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.register.page_title'|trans }}{% endblock %}

{% set input_class = 'block w-full rounded-md border border-gray-300 px-3 py-1.5 text-gray-900 placeholder:text-gray-400 focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600 focus:outline-none sm:text-sm' %}

{% block body %}
<div class="flex min-h-full">
    <div class="flex flex-1 flex-col justify-center px-4 py-12 sm:px-6 lg:flex-none lg:px-20 xl:px-24">
        <div class="mx-auto w-full max-w-sm lg:w-96">
            <div>
                <h1 class="text-2xl font-bold tracking-tight text-indigo-600">⛺ Camping</h1>
                <h2 class="mt-8 text-2xl font-bold tracking-tight text-gray-900">{{ 'auth.register.heading'|trans }}</h2>
                <p class="mt-2 text-sm text-gray-500">
                    {{ 'auth.register.already_registered'|trans }}
                    <a href="{{ path('app_login') }}" class="font-semibold text-indigo-600 hover:text-indigo-500">{{ 'auth.register.login_link'|trans }}</a>
                </p>
            </div>

            <div class="mt-10">
                {% for flash_error in app.flashes('verify_email_error') %}
                    <div class="mb-6 rounded-md bg-red-50 p-4 text-sm text-red-700" role="alert">{{ flash_error }}</div>
                {% endfor %}

                {{ form_start(registrationForm, {attr: {class: 'space-y-6'}}) }}
                    <div>
                        {{ form_label(registrationForm.email, 'auth.email_label'|trans, {label_attr: {class: 'block text-sm font-medium text-gray-900'}}) }}
                        <div class="mt-2">
                            {{ form_widget(registrationForm.email, {attr: {class: input_class, autocomplete: 'email'}}) }}
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(registrationForm.email) }}</div>
                    </div>

                    <div>
                        {{ form_label(registrationForm.plainPassword, 'auth.password_label'|trans, {label_attr: {class: 'block text-sm font-medium text-gray-900'}}) }}
                        <div class="mt-2">
                            {{ form_widget(registrationForm.plainPassword, {attr: {class: input_class}}) }}
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(registrationForm.plainPassword) }}</div>
                    </div>

                    <div>
                        <div class="flex items-center gap-2">
                            {{ form_widget(registrationForm.agreeTerms, {attr: {class: 'size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600'}}) }}
                            {{ form_label(registrationForm.agreeTerms, 'auth.register.agree_terms'|trans, {label_attr: {class: 'block text-sm text-gray-900'}}) }}
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(registrationForm.agreeTerms) }}</div>
                    </div>

                    <div>
                        <button type="submit"
                                class="flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                            {{ 'auth.register.submit'|trans }}
                        </button>
                    </div>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
    <div class="relative hidden w-0 flex-1 lg:block">
        <img src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?auto=format&fit=crop&w=1908&q=80" alt="" class="absolute inset-0 size-full object-cover">
    </div>
</div>
{% endblock %}
