    <script>
    (function () {
      var i18n = {
        errorRating: '{{ 'home.testimonial_modal.error_rating'|trans|e('js') }}',
        submitting: '{{ 'home.testimonial_modal.submitting'|trans|e('js') }}',
        submit: '{{ 'home.testimonial_modal.submit'|trans|e('js') }}',
        errorGeneric: '{{ 'home.testimonial_modal.error_generic'|trans|e('js') }}',
        errorNetwork: '{{ 'home.testimonial_modal.error_network'|trans|e('js') }}',
      };

      var stars = document.querySelectorAll('.star-input-btn');
      var ratingInput = document.getElementById('t-rating');
      var form = document.getElementById('testimonial-form');
      var submitBtn = document.getElementById('testimonial-submit-btn');
      var errorDiv = document.getElementById('testimonial-error');
      var formWrap = document.getElementById('testimonial-form-wrap');
      var successDiv = document.getElementById('testimonial-success');

      if (!form) return;

      function setStars(value) {
        stars.forEach(function (btn) {
          var v = parseInt(btn.dataset.value, 10);
          btn.classList.toggle('text-green-600', v <= value);
          btn.classList.toggle('dark:text-green-400', v <= value);
          btn.classList.toggle('text-gray-300', v > value);
          btn.classList.toggle('dark:text-gray-600', v > value);
        });
        ratingInput.value = value;
      }

      function resetModal() {
        form.reset();
        setStars(0);
        errorDiv.classList.add('hidden');
        formWrap.classList.remove('hidden');
        successDiv.classList.add('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = i18n.submit;
      }

      stars.forEach(function (btn) {
        btn.addEventListener('click', function () {
          setStars(parseInt(btn.dataset.value, 10));
        });
        btn.addEventListener('mouseenter', function () {
          var hv = parseInt(btn.dataset.value, 10);
          stars.forEach(function (b) {
            var v = parseInt(b.dataset.value, 10);
            b.classList.toggle('text-green-600', v <= hv);
            b.classList.toggle('text-gray-300', v > hv);
          });
        });
      });

      document.getElementById('star-rating-input').addEventListener('mouseleave', function () {
        setStars(parseInt(ratingInput.value, 10));
      });

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var rating = parseInt(ratingInput.value, 10);
        if (rating < 1 || rating > 5) {
          errorDiv.textContent = i18n.errorRating;
          errorDiv.classList.remove('hidden');
          return;
        }
        errorDiv.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = i18n.submitting;
        try {
          var res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
          });
          var data = await res.json();
          if (data.success) {
            formWrap.classList.add('hidden');
            successDiv.classList.remove('hidden');
          } else {
            errorDiv.textContent = data.error || i18n.errorGeneric;
            errorDiv.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = i18n.submit;
          }
        } catch (err) {
          errorDiv.textContent = i18n.errorNetwork;
          errorDiv.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = i18n.submit;
        }
      });

      document.addEventListener('DOMContentLoaded', function () {
        var testimonialDialog = document.getElementById('testimonial-modal');
        if (testimonialDialog) {
          testimonialDialog.addEventListener('close', resetModal);
          testimonialDialog.addEventListener('click', function(e) {
            if (e.target === testimonialDialog) testimonialDialog.close();
          });
        }
        document.querySelectorAll('[data-open]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var target = document.getElementById(btn.getAttribute('data-open'));
            if (target) target.showModal();
          });
        });
        document.querySelectorAll('[data-close]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var target = document.getElementById(btn.getAttribute('data-close'));
            if (target) target.close();
          });
        });
      });
    })();
    </script>
