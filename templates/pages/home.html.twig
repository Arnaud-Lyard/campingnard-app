{% extends 'base.html.twig' %}

{% set page_description = 'seo.home.description'|trans %}

{% block title %}{{ 'seo.home.title'|trans }}{% endblock %}

{% block page_hreflang %}
<link rel="alternate" hreflang="fr" href="{{ absolute_url(path('home', {'_locale': 'fr'})) }}">
<link rel="alternate" hreflang="en" href="{{ absolute_url(path('home', {'_locale': 'en'})) }}">
<link rel="alternate" hreflang="x-default" href="{{ absolute_url(path('home', {'_locale': 'fr'})) }}">
{% endblock %}

{% block body %}
<div class="bg-white dark:bg-gray-900">
  <!-- Header -->
  <header class="absolute inset-x-0 top-0 z-50">
    <nav aria-label="Global" class="flex items-center justify-between p-6 lg:px-8">
      <div class="flex items-center gap-x-4 lg:flex-1">
        <a href="#" class="-m-1.5 p-1.5">
          <span class="sr-only">Campingnard</span>
          <img src="{{ asset('images/campingnard-logo-light.svg') }}" alt="Campingnard" class="h-10 w-auto dark:hidden">
          <img src="{{ asset('images/campingnard-logo-dark.svg') }}" alt="Campingnard" class="h-10 w-auto not-dark:hidden">
        </a>
        {{ include('pages/_partials/_language_switcher.html.twig') }}
      </div>
      <div class="flex lg:hidden">
        <button type="button" data-open="mobile-menu" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700 dark:text-gray-200">
          <span class="sr-only">{{ 'nav.open_main_menu'|trans }}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
            <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>
      <div class="hidden lg:flex lg:gap-x-12">
      </div>
      <div class="hidden lg:flex lg:flex-1 lg:justify-end">
        {% if app.user %}
          <a href="{{ path('user_weather_index') }}" class="text-sm/6 font-semibold text-gray-900 dark:text-white">{{ 'nav.dashboard'|trans }} <span aria-hidden="true">&rarr;</span></a>
        {% else %}
          <a href="{{ path('app_login') }}" class="text-sm/6 font-semibold text-gray-900 dark:text-white">{{ 'nav.login'|trans }} <span aria-hidden="true">&rarr;</span></a>
        {% endif %}
      </div>
    </nav>
    <dialog id="mobile-menu" class="backdrop:bg-transparent lg:hidden overflow-y-auto bg-white p-6 sm:ring-1 sm:ring-gray-900/10 dark:bg-gray-900 dark:sm:ring-gray-100/10" style="position:fixed;inset:0 0 0 auto;width:100%;max-width:24rem;height:100%;max-height:100%;margin:0;border:0">
            <div class="flex items-center justify-between">
              <a href="#" class="-m-1.5 p-1.5">
                <span class="sr-only">Campingnard</span>
                <img src="{{ asset('images/campingnard-logo-light.svg') }}" alt="Campingnard" class="h-10 w-auto dark:hidden">
                <img src="{{ asset('images/campingnard-logo-dark.svg') }}" alt="Campingnard" class="h-10 w-auto not-dark:hidden">
              </a>
              <button type="button" data-close="mobile-menu" class="-m-2.5 rounded-md p-2.5 text-gray-700 dark:text-gray-200">
                <span class="sr-only">{{ 'nav.close_menu'|trans }}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
                  <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            </div>
            <div class="mt-6 flow-root">
              <div class="-my-6 divide-y divide-gray-500/10 dark:divide-white/10">
                <div class="space-y-2 py-6">
                </div>
                <div class="py-6">
                  {% if app.user %}
                    <a href="{{ path('user_weather_index') }}" class="-mx-3 block rounded-lg px-3 py-2.5 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5">{{ 'nav.dashboard'|trans }}</a>
                  {% else %}
                    <a href="{{ path('app_login') }}" class="-mx-3 block rounded-lg px-3 py-2.5 text-base/7 font-semibold text-gray-900 hover:bg-gray-50 dark:text-white dark:hover:bg-white/5">{{ 'nav.login'|trans }}</a>
                  {% endif %}
                </div>
              </div>
            </div>
    </dialog>
  </header>

  <main>
    <!-- Flash messages -->
    {% for label, messages in app.flashes(['success', 'error', 'info']) %}
      {% for message in messages %}
      <div class="fixed top-4 right-4 z-50 flex items-center gap-x-3 rounded-xl px-5 py-3 text-sm font-semibold shadow-lg ring-1 {{ label == 'success' ? 'bg-green-50 text-green-800 ring-green-200 dark:bg-green-900/20 dark:text-green-300 dark:ring-green-800' : label == 'error' ? 'bg-red-50 text-red-800 ring-red-200 dark:bg-red-900/20 dark:text-red-300 dark:ring-red-800' : 'bg-blue-50 text-blue-800 ring-blue-200 dark:bg-blue-900/20 dark:text-blue-300 dark:ring-blue-800' }}">
        {{ message }}
      </div>
      {% endfor %}
    {% endfor %}

    <!-- Hero section -->
    <div class="relative isolate pt-14">
      <svg aria-hidden="true" class="absolute inset-0 -z-10 size-full stroke-gray-200 dark:stroke-white/10" style="mask-image: radial-gradient(100% 100% at top right, white, transparent)">
        <defs>
          <pattern id="83fd4e5a-9d52-42fc-97b6-718e5d7ee527" width="200" height="200" x="50%" y="-1" patternUnits="userSpaceOnUse">
            <path d="M100 200V.5M.5 .5H200" fill="none" />
          </pattern>
        </defs>
        <svg x="50%" y="-1" class="overflow-visible fill-gray-50 dark:fill-gray-800/50">
          <path d="M-100.5 0h201v201h-201Z M699.5 0h201v201h-201Z M499.5 400h201v201h-201Z M-300.5 600h201v201h-201Z" stroke-width="0" />
        </svg>
        <rect width="100%" height="100%" fill="url(#83fd4e5a-9d52-42fc-97b6-718e5d7ee527)" stroke-width="0" />
      </svg>
      <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:flex lg:items-center lg:gap-x-10 lg:px-8 lg:py-40">
        <div class="mx-auto max-w-2xl lg:mx-0 lg:flex-auto">
          <div class="flex">
            <div class="relative flex items-center gap-x-4 rounded-full bg-white px-4 py-1 text-sm/6 text-gray-600 ring-1 ring-gray-900/10 hover:ring-gray-900/20 dark:bg-white/5 dark:text-gray-300 dark:ring-white/10 dark:hover:ring-white/20">
              <span class="font-semibold text-green-600 dark:text-green-400">{{ 'home.badge.label'|trans }}</span>
              <span aria-hidden="true" class="h-4 w-px bg-gray-900/10 dark:bg-white/10"></span>
              <a href="#" class="flex items-center gap-x-1">
                <span aria-hidden="true" class="absolute inset-0"></span>
                {{ 'home.badge.text'|trans }}
                <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="-mr-2 size-5 text-gray-400">
                  <path d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
          <h1 class="mt-10 text-5xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-7xl dark:text-white">{{ 'home.hero.heading'|trans }}</h1>
          <p class="mt-8 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8 dark:text-gray-400">{{ 'home.hero.description'|trans }}</p>
          <div class="mt-10 flex items-center gap-x-6">
            <a href="{{ path("app_register") }}" class="rounded-md bg-green-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-green-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600 dark:bg-green-500 dark:hover:bg-green-400 dark:focus-visible:outline-green-500">{{ 'home.hero.cta_primary'|trans }}</a>
            <a href="#features" class="text-sm/6 font-semibold text-gray-900 dark:text-white">{{ 'home.hero.cta_secondary'|trans }} <span aria-hidden="true">→</span></a>
          </div>
        </div>
        <div class="mt-16 sm:mt-24 lg:mt-0 lg:shrink-0 lg:grow">
          <svg role="img" viewBox="0 0 366 729" class="mx-auto w-91.5 max-w-full drop-shadow-xl">
            <title>{{ 'nav.app_screenshot'|trans }}</title>
            <defs>
              <clipPath id="2ade4387-9c63-4fc4-b754-10e687a0d332">
                <rect width="316" height="684" rx="36" />
              </clipPath>
            </defs>
            <path d="M363.315 64.213C363.315 22.99 341.312 1 300.092 1H66.751C25.53 1 3.528 22.99 3.528 64.213v44.68l-.857.143A2 2 0 0 0 1 111.009v24.611a2 2 0 0 0 1.671 1.973l.95.158a2.26 2.26 0 0 1-.093.236v26.173c.212.1.398.296.541.643l-1.398.233A2 2 0 0 0 1 167.009v47.611a2 2 0 0 0 1.671 1.973l1.368.228c-.139.319-.314.533-.511.653v16.637c.221.104.414.313.56.689l-1.417.236A2 2 0 0 0 1 237.009v47.611a2 2 0 0 0 1.671 1.973l1.347.225c-.135.294-.302.493-.49.607v377.681c0 41.213 22 63.208 63.223 63.208h95.074c.947-.504 2.717-.843 4.745-.843l.141.001h.194l.086-.001 33.704.005c1.849.043 3.442.37 4.323.838h95.074c41.222 0 63.223-21.999 63.223-63.212v-394.63c-.259-.275-.48-.796-.63-1.47l-.011-.133 1.655-.276A2 2 0 0 0 366 266.62v-77.611a2 2 0 0 0-1.671-1.973l-1.712-.285c.148-.839.396-1.491.698-1.811V64.213Z" fill="#4B5563" />
            <path d="M16 59c0-23.748 19.252-43 43-43h246c23.748 0 43 19.252 43 43v615c0 23.196-18.804 42-42 42H58c-23.196 0-42-18.804-42-42V59Z" fill="#343E4E" />
            <foreignObject width="316" height="684" clip-path="url(#2ade4387-9c63-4fc4-b754-10e687a0d332)" transform="translate(24 24)">
            <img src="{{ asset('captures/Screenshot_meteo.jpg') }}" alt="">
            </foreignObject>
          </svg>
        </div>
      </div>
    </div>

    <!-- Feature section -->
    <div class="mx-auto mt-32 max-w-7xl sm:mt-56 sm:px-6 lg:px-8">
      <div class="relative isolate overflow-hidden bg-gray-900 px-6 py-20 sm:rounded-3xl sm:px-10 sm:py-24 lg:py-24 xl:px-24 dark:bg-gray-800/50 dark:after:pointer-events-none dark:after:absolute dark:after:inset-0 dark:after:inset-ring dark:after:inset-ring-white/10 dark:after:sm:rounded-3xl">
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-center lg:gap-y-0">
          <div class="lg:row-start-2 lg:max-w-md">
            <h2 class="text-3xl font-semibold tracking-tight text-balance text-white sm:text-4xl">{{ 'home.feature_weather.heading'|trans }}</h2>
            <p class="mt-6 text-lg/8 text-gray-300">{{ 'home.feature_weather.description'|trans }}</p>
          </div>

          <img width="2432" height="1442" src="{{ asset('captures/Screenshot_backoffice.png') }}" alt="{{ 'nav.app_preview_alt'|trans }}" class="relative -z-20 max-w-xl min-w-full rounded-xl shadow-xl ring-1 ring-white/10 lg:row-span-4 lg:w-5xl lg:max-w-none" />
          <div class="max-w-xl lg:row-start-3 lg:mt-10 lg:max-w-md lg:border-t lg:border-white/10 lg:pt-10">
            <dl class="max-w-xl space-y-8 text-base/7 text-gray-300 lg:max-w-none">
              <div class="relative">
                <dt class="ml-9 inline-block font-semibold text-white">
                  <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="absolute top-1 left-1 size-5 text-green-400">
                    <path d="M5.5 17a4.5 4.5 0 0 1-1.44-8.765 4.5 4.5 0 0 1 8.302-3.046 3.5 3.5 0 0 1 4.504 4.272A4 4 0 0 1 15 17H5.5Zm3.75-2.75a.75.75 0 0 0 1.5 0V9.66l1.95 2.1a.75.75 0 1 0 1.1-1.02l-3.25-3.5a.75.75 0 0 0-1.1 0l-3.25 3.5a.75.75 0 1 0 1.1 1.02l1.95-2.1v4.59Z" clip-rule="evenodd" fill-rule="evenodd" />
                  </svg>
                  {{ 'home.feature_weather.hourly_title'|trans }}
                </dt>
                <dd class="inline">{{ 'home.feature_weather.hourly_text'|trans }}</dd>
              </div>
              <div class="relative">
                <dt class="ml-9 inline-block font-semibold text-white">
                  <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="absolute top-1 left-1 size-5 text-green-400">
                    <path d="M10 1a4.5 4.5 0 0 0-4.5 4.5V9H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-.5V5.5A4.5 4.5 0 0 0 10 1Zm3 8V5.5a3 3 0 1 0-6 0V9h6Z" clip-rule="evenodd" fill-rule="evenodd" />
                  </svg>
                  {{ 'home.feature_weather.forecast_title'|trans }}
                </dt>
                <dd class="inline">{{ 'home.feature_weather.forecast_text'|trans }}</dd>
              </div>
              <div class="relative">
                <dt class="ml-9 inline-block font-semibold text-white">
                  <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="absolute top-1 left-1 size-5 text-green-400">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2Zm.75 4.75a.75.75 0 0 0-1.5 0v4.5l-1.72-1.72a.75.75 0 0 0-1.06 1.06l3 3a.75.75 0 0 0 1.06 0l3-3a.75.75 0 1 0-1.06-1.06l-1.72 1.72v-4.5Z" />
                  </svg>
                  {{ 'home.feature_weather.sunrise_title'|trans }}
                </dt>
                <dd class="inline">{{ 'home.feature_weather.sunrise_text'|trans }}</dd>
              </div>
            </dl>
          </div>
        </div>
        <div aria-hidden="true" class="pointer-events-none absolute top-1/2 left-12 -z-10 -translate-y-1/2 transform-gpu blur-3xl lg:top-auto lg:-bottom-48 lg:translate-y-0">
          <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="aspect-1155/678 w-288.75 bg-linear-to-tr from-[#ff80b5] to-[#9089fc] opacity-25 dark:opacity-20"></div>
        </div>
      </div>
    </div>

    <!-- Feature section -->
    <div class="mx-auto mt-32 max-w-7xl px-6 sm:mt-56 lg:px-8">
      <div id="features" class="mx-auto max-w-2xl lg:text-center">
        <h2 class="text-base/7 font-semibold text-green-600 dark:text-green-400">{{ 'home.features.overline'|trans }}</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl lg:text-balance dark:text-white">{{ 'home.features.heading'|trans }}</p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">{{ 'home.features.description'|trans }}</p>
      </div>
      <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
        <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-3">
          <div class="flex flex-col">
            <dt class="flex items-center gap-x-3 text-base/7 font-semibold text-gray-900 dark:text-white">
              <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="size-5 flex-none text-green-600 dark:text-green-400">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M5.5 17a4.5 4.5 0 0 1-1.44-8.765 4.5 4.5 0 0 1 8.302-3.046 3.5 3.5 0 0 1 4.504 4.272A4 4 0 0 1 15 17H5.5Zm3.75-2.75a.75.75 0 0 0 1.5 0V9.66l1.95 2.1a.75.75 0 1 0 1.1-1.02l-3.25-3.5a.75.75 0 0 0-1.1 0l-3.25 3.5a.75.75 0 1 0 1.1 1.02l1.95-2.1v4.59Z" />
              </svg>
              {{ 'home.features.weather_title'|trans }}
            </dt>
            <dd class="mt-4 flex flex-auto flex-col text-base/7 text-gray-600 dark:text-gray-400">
              <p class="flex-auto">{{ 'home.features.weather_text'|trans }}</p>
              <p class="mt-6">
                <a href="{{ path('app_register') }}" class="text-sm/6 font-semibold text-green-600 hover:text-green-500 dark:text-green-400 dark:hover:text-green-300">{{ 'home.features.try_free'|trans }} <span aria-hidden="true">→</span></a>
              </p>
            </dd>
          </div>
          <div class="flex flex-col">
            <dt class="flex items-center gap-x-3 text-base/7 font-semibold text-gray-900 dark:text-white">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-5 flex-none text-green-600 dark:text-green-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m-6 9 2 2 4-4" />
              </svg>
              {{ 'home.features.checklist_title'|trans }}
            </dt>
            <dd class="mt-4 flex flex-auto flex-col text-base/7 text-gray-600 dark:text-gray-400">
              <p class="flex-auto">{{ 'home.features.checklist_text'|trans }}</p>
              <p class="mt-6">
                <a href="{{ path('app_register') }}" class="text-sm/6 font-semibold text-green-600 hover:text-green-500 dark:text-green-400 dark:hover:text-green-300">{{ 'home.features.try_free'|trans }} <span aria-hidden="true">→</span></a>
              </p>
            </dd>
          </div>
          <div class="flex flex-col">
            <dt class="flex items-center gap-x-3 text-base/7 font-semibold text-gray-900 dark:text-white">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-5 flex-none text-green-600 dark:text-green-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
              {{ 'home.features.battery_title'|trans }}
            </dt>
            <dd class="mt-4 flex flex-auto flex-col text-base/7 text-gray-600 dark:text-gray-400">
              <p class="flex-auto">{{ 'home.features.battery_text'|trans }}</p>
              <p class="mt-6">
                <a href="{{ path('app_register') }}" class="text-sm/6 font-semibold text-green-600 hover:text-green-500 dark:text-green-400 dark:hover:text-green-300">{{ 'home.features.try_free'|trans }} <span aria-hidden="true">→</span></a>
              </p>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Testimonials section -->
    <div class="relative isolate mt-32 sm:mt-56 sm:pt-32">
      <svg aria-hidden="true" class="absolute inset-0 -z-10 hidden size-full stroke-gray-200 sm:block dark:stroke-white/10" style="mask-image: radial-gradient(64rem 64rem at top, white, transparent)">
        <defs>
          <pattern id="55d3d46d-692e-45f2-becd-d8bdc9344f45" width="200" height="200" x="50%" y="0" patternUnits="userSpaceOnUse">
            <path d="M.5 200V.5H200" fill="none" />
          </pattern>
        </defs>
        <svg x="50%" y="0" class="overflow-visible fill-gray-50 dark:fill-gray-800/20">
          <path d="M-200.5 0h201v201h-201Z M599.5 0h201v201h-201Z M399.5 400h201v201h-201Z M-400.5 600h201v201h-201Z" stroke-width="0" />
        </svg>
        <rect width="100%" height="100%" fill="url(#55d3d46d-692e-45f2-becd-d8bdc9344f45)" stroke-width="0" />
      </svg>
      <div class="relative">
        <div aria-hidden="true" class="absolute inset-x-0 top-1/2 -z-10 -translate-y-1/2 transform-gpu overflow-hidden opacity-30 blur-3xl">
          <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="ml-[max(50%,38rem)] aspect-1313/771 w-328.25 bg-linear-to-tr from-[#99f6e4] to-[#22c55e]"></div>
        </div>
        <div aria-hidden="true" class="absolute inset-x-0 top-0 -z-10 flex transform-gpu overflow-hidden pt-32 opacity-25 blur-3xl sm:pt-40 xl:justify-end">
          <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="-ml-88 aspect-1313/771 w-328.25 flex-none origin-top-right rotate-30 bg-linear-to-tr from-[#99f6e4] to-[#22c55e] xl:mr-[calc(50%-12rem)] xl:ml-0"></div>
        </div>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-2xl text-center">
