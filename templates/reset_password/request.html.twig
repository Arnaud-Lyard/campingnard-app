{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.reset_request.page_title'|trans }}{% endblock %}

{% set input_class = 'block w-full rounded-md border border-gray-300 px-3 py-1.5 text-gray-900 placeholder:text-gray-400 focus:border-green-600 focus:ring-2 focus:ring-green-600 focus:outline-none sm:text-sm' %}

{% block body %}
<div class="flex min-h-full">
    <div class="flex flex-1 flex-col justify-center px-4 py-12 sm:px-6 lg:flex-none lg:px-20 xl:px-24">
        <div class="mx-auto w-full max-w-sm lg:w-96">
            <div>
                <a href="{{ path('app_home') }}" class="inline-block">
                    <img src="{{ asset('images/campingnard-logo-light.svg') }}" alt="Campingnard" class="h-10 w-auto dark:hidden">
                    <img src="{{ asset('images/campingnard-logo-dark.svg') }}" alt="Campingnard" class="h-10 w-auto not-dark:hidden">
                </a>
                <h2 class="mt-8 text-2xl font-bold tracking-tight text-gray-900">{{ 'auth.reset_request.heading'|trans }}</h2>
                <p class="mt-2 text-sm text-gray-500">
                    {{ 'auth.reset_request.intro'|trans }}
                </p>
            </div>

            <div class="mt-10">
                {{ form_start(requestForm, {attr: {class: 'space-y-6'}}) }}
                    <div>
                        {{ form_label(requestForm.email, 'auth.email_label'|trans, {label_attr: {class: 'block text-sm font-medium text-gray-900'}}) }}
                        <div class="mt-2">
                            {{ form_widget(requestForm.email, {attr: {class: input_class, autocomplete: 'email', placeholder: 'auth.email_placeholder'|trans}}) }}
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(requestForm.email) }}</div>
                    </div>

                    <div>
                        <button type="submit"
                                class="flex w-full justify-center rounded-md bg-green-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600">
                            {{ 'auth.reset_request.submit'|trans }}
                        </button>
                    </div>
                {{ form_end(requestForm) }}

                <p class="mt-6 text-sm text-gray-500">
                    <a href="{{ path('app_login') }}" class="font-semibold text-green-600 hover:text-green-500">{{ 'auth.back_to_login'|trans }}</a>
                </p>
            </div>
        </div>
    </div>
    <div class="relative hidden w-0 flex-1 lg:block">
        <img src="{{ asset('images/campingnard-register-hero.png') }}" alt="" class="absolute inset-0 size-full object-cover">
    </div>
</div>
{% endblock %}
