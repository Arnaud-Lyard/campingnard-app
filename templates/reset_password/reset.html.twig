{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.reset.page_title'|trans }}{% endblock %}

{% set input_class = 'block w-full rounded-md border border-gray-300 px-3 py-1.5 text-gray-900 placeholder:text-gray-400 focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600 focus:outline-none sm:text-sm' %}

{% block body %}
<div class="flex min-h-full">
    <div class="flex flex-1 flex-col justify-center px-4 py-12 sm:px-6 lg:flex-none lg:px-20 xl:px-24">
        <div class="mx-auto w-full max-w-sm lg:w-96">
            <div>
                <h1 class="text-2xl font-bold tracking-tight text-indigo-600">⛺ Camping</h1>
                <h2 class="mt-8 text-2xl font-bold tracking-tight text-gray-900">{{ 'auth.reset.heading'|trans }}</h2>
            </div>

            <div class="mt-10">
                {{ form_start(resetForm, {attr: {class: 'space-y-6'}}) }}
                    <div>
                        {{ form_label(resetForm.plainPassword.first, 'auth.reset.new_password_label'|trans, {label_attr: {class: 'block text-sm font-medium text-gray-900'}}) }}
                        <div class="mt-2">
                            {{ form_widget(resetForm.plainPassword.first, {attr: {class: input_class}}) }}
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(resetForm.plainPassword.first) }}</div>
                    </div>

                    <div>
                        {{ form_label(resetForm.plainPassword.second, 'auth.reset.repeat_password_label'|trans, {label_attr: {class: 'block text-sm font-medium text-gray-900'}}) }}
                        <div class="mt-2">
                            {{ form_widget(resetForm.plainPassword.second, {attr: {class: input_class}}) }}
                        </div>
                        <div class="mt-1 text-sm text-red-600">{{ form_errors(resetForm.plainPassword.second) }}</div>
                    </div>

                    <div>
                        <button type="submit"
                                class="flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                            {{ 'auth.reset.submit'|trans }}
                        </button>
                    </div>
                {{ form_end(resetForm) }}
            </div>
        </div>
    </div>
    <div class="relative hidden w-0 flex-1 lg:block">
        <img src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?auto=format&fit=crop&w=1908&q=80" alt="" class="absolute inset-0 size-full object-cover">
    </div>
</div>
{% endblock %}
