{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.check_email.page_title'|trans }}{% endblock %}

{% block body %}
<div class="flex min-h-full">
    <div class="flex flex-1 flex-col justify-center px-4 py-12 sm:px-6 lg:flex-none lg:px-20 xl:px-24">
        <div class="mx-auto w-full max-w-sm lg:w-96">
            <div>
                <a href="{{ path('app_home') }}" class="inline-block">
                    <img src="{{ asset('images/campingnard-logo-light.svg') }}" alt="Campingnard" class="h-10 w-auto dark:hidden">
                    <img src="{{ asset('images/campingnard-logo-dark.svg') }}" alt="Campingnard" class="h-10 w-auto not-dark:hidden">
                </a>
                <h2 class="mt-8 text-2xl font-bold tracking-tight text-gray-900">{{ 'auth.check_email.heading'|trans }}</h2>
            </div>

            <div class="mt-10 space-y-4 text-sm text-gray-500">
                <p>
                    {{ 'auth.check_email.sent'|trans({'%duration%': resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle')}) }}
                </p>
                <p>
                    {{ 'auth.check_email.spam_before'|trans }}
                    <a href="{{ path('app_forgot_password_request') }}" class="font-semibold text-indigo-600 hover:text-indigo-500">{{ 'auth.check_email.retry'|trans }}</a>.
                </p>
            </div>

            <p class="mt-6 text-sm text-gray-500">
                <a href="{{ path('app_login') }}" class="font-semibold text-indigo-600 hover:text-indigo-500">{{ 'auth.back_to_login'|trans }}</a>
            </p>
        </div>
    </div>
    <div class="relative hidden w-0 flex-1 lg:block">
        <img src="{{ asset('images/campingnard-register-hero.png') }}" alt="" class="absolute inset-0 size-full object-cover">
    </div>
</div>
{% endblock %}
